@startuml
skinparam monochrome true
skinparam packageStyle rect
skinparam defaultFontName Arial
skinparam shadowing false

|Пользователь (Студент/Преподаватель)|
start
:Аутентификация;

if (Роль?) is (Преподаватель/Админ) then
  split
    :Управление темами;
  split again
    :Создание/Редактирование задач;
    :Загрузка тест-кейсов (In/Out);
  split again
    :Управление курсами и группами;
    :Создание заданий (Assignments);
  end split
else (Студент)
  :Просмотр задач / заданий;
  :Выбор задачи;
  :Реализация решения;
  :Отправка кода;

  |API Бэкенда|
  :Валидация запроса;
  :Проверка активных попыток;
  if (Уже выполняется?) then (да)
    :Возврат ошибки (400);
    stop
  else (нет)
    :Создание попытки (Статус: Created);
    :Добавление в очередь RabbitMQ (rankode-req);
    
    |#GhostWhite|Внешний Раннер|
    :Получение попытки;
    :Компиляция и выполнение кода;
    :Запуск на тест-кейсах;
    :Сбор метрик (Время, Память);
    :Отправка результатов в RabbitMQ (rankode-resp);
    
    |Валидатор Бэкенда|
    :Обработка результатов;
    if (Ошибка выполнения?) then (да)
      :Обновление статуса (Ошибка/Таймаут/Память);
    else (нет)
      while (Есть еще тесты?) is (да)
        :Получение ожидаемого вывода;
        if (Вывод совпадает?) then (нет)
          :Статус: Неверный ответ (WA);
          stop
        endif
      endwhile (нет)
      :Статус: Успешно (OK);
      :Сохранение метрик;
      if (Первое успешное решение?) then (да)
        :Увеличение счетчика решений задачи;
        :Увеличение рейтинга (Elo) пользователя;
        if (Это задание курса?) then (да)
          :Автоматическое выставление оценки;
        endif
      endif
    endif
  endif
endif

|Пользователь (Студент/Преподаватель)|
:Просмотр статуса / лидерборда / оценок;
stop
@enduml
